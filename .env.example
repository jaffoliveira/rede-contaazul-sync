# Porta do servidor (opcional, padrao: 3000)
PORT=3000

# URL de callback OAuth2 (deve ser registrada no Portal do Desenvolvedor da Conta Azul)
# Exemplo local: http://localhost:3000/api/auth/callback
# Exemplo producao: https://seudominio.com/api/auth/callback
REDIRECT_URI=http://localhost:3000/api/auth/callback

# =============================================================================
# CREDENCIAIS CONTA AZUL - PLACE e STATION (mesmo login)
# =============================================================================
CA_PLACE_CLIENT_ID=seu_client_id_place
CA_PLACE_CLIENT_SECRET=seu_client_secret_place
CA_STATION_CLIENT_ID=seu_client_id_station
CA_STATION_CLIENT_SECRET=seu_client_secret_station

# =============================================================================
# CREDENCIAIS CONTA AZUL - SIDE e ZONE (mesmo login)
# =============================================================================
CA_SIDE_CLIENT_ID=seu_client_id_side
CA_SIDE_CLIENT_SECRET=seu_client_secret_side
CA_ZONE_CLIENT_ID=seu_client_id_zone
CA_ZONE_CLIENT_SECRET=seu_client_secret_zone

# =============================================================================
# IDs DE CONFIGURACAO (obter via API GET /v1/centro-custo e /v1/conta)
# =============================================================================

# PLACE
CA_PLACE_COST_CENTER_ID=uuid-do-centro-de-custo-place
CA_PLACE_ACCOUNT_ID=uuid-da-conta-cc-place
CA_PLACE_CATEGORY_ID=uuid-da-categoria-vendas-place

# STATION
CA_STATION_COST_CENTER_ID=uuid-do-centro-de-custo-station
CA_STATION_ACCOUNT_ID=uuid-da-conta-cc-station
CA_STATION_CATEGORY_ID=uuid-da-categoria-vendas-station

# SIDE
CA_SIDE_COST_CENTER_ID=uuid-do-centro-de-custo-side
CA_SIDE_ACCOUNT_ID=uuid-da-conta-cc-side
CA_SIDE_CATEGORY_ID=uuid-da-categoria-vendas-side

# ZONE
CA_ZONE_COST_CENTER_ID=uuid-do-centro-de-custo-zone
CA_ZONE_ACCOUNT_ID=uuid-da-conta-cc-zone
CA_ZONE_CATEGORY_ID=uuid-da-categoria-vendas-zone
